# /public/.htaccess
# Hostinger Apache — Vite SPA routing fix

Options -MultiViews
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Serve real files/folders if they exist (CSS, JS, images etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback — all other routes → index.html with 200 (NOT redirect)
RewriteRule ^ /index.html [L]

# Security headers (bonus SEO trust signal)
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# Gzip compression (Core Web Vitals)
AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json

# Browser caching for static assets
<FilesMatch "\.(js|css|png|jpg|jpeg|webp|svg|ico|woff2)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# HTML — never cache (always fresh for SEO re-crawls)
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>